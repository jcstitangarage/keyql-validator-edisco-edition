{
  "name": "purview-keyql-tester",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Purview eDiscovery KeyQL tester — parse, validate, and dry-run queries before filing real cases.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "parse": "tsx src/cli.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.3",
    "@codemirror/commands": "^6.8.0",
    "@codemirror/language": "^6.10.8",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "@lezer/highlight": "^1.2.1",
    "chevrotain": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.2"
  }
}
